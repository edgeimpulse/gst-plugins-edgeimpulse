FROM rust:1.90-slim-bullseye

# Install GStreamer dev + runtime + codec plugins for test pipelines
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    build-essential \
    pkg-config \
    libclang-dev \
    clang \
    cmake \
    make \
    git \
    # GStreamer core
    libgstreamer1.0-dev \
    libgstreamer-plugins-base1.0-dev \
    gstreamer1.0-plugins-base \
    gstreamer1.0-plugins-good \
    gstreamer1.0-libav \
    gstreamer1.0-tools \
    # Rendering deps (for overlay element)
    libcairo2-dev \
    libpango1.0-dev \
    # Video test source and format conversion
    gstreamer1.0-plugins-bad \
    # Clean up
    && rm -rf /var/lib/apt/lists/*

RUN rustup component add rustfmt

WORKDIR /app

# Copy source (excluding target/ via .dockerignore)
COPY . .

# Build with FFI mode — requires EI_PROJECT_ID + EI_API_KEY at build time
ARG EI_PROJECT_ID
ARG EI_API_KEY
ARG EI_MODEL
ARG EI_ENGINE=tflite
ARG USE_FULL_TFLITE=1

ENV EI_PROJECT_ID=${EI_PROJECT_ID}
ENV EI_API_KEY=${EI_API_KEY}
ENV EI_MODEL=${EI_MODEL}
ENV EI_ENGINE=${EI_ENGINE}
ENV USE_FULL_TFLITE=${USE_FULL_TFLITE}

# Build plugin + test binary
RUN cargo build --release && \
    cargo test --release --no-run

# Set plugin path so GStreamer finds our plugin
ENV GST_PLUGIN_PATH=/app/target/release

# Run tests
CMD ["cargo", "test", "--release", "--test", "e2e", "--", "--nocapture"]
